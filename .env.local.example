# Copy this file to .env.local and fill in your values

# Anthropic (Tuned For key — used for free tier books 1-3)
ANTHROPIC_API_KEY=sk-ant-...

# Ideogram (Tuned For key — used for free tier books 1-3)
IDEOGRAM_API_KEY=...

# Supabase (server-side, bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase (client-side, anon key, RLS applies — public read only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Base URL (for server-side fetch in book reader page — use your Vercel URL in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
